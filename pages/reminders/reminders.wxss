.container { background: #f2f9f4; min-height: 100vh; padding-bottom: 100rpx; }
.page-header { padding: 48rpx 36rpx 28rpx; }
.page-title { display:block; font-size: 40rpx; font-weight: 800; color: #0d2b1f; }
.page-subtitle { display:block; font-size: 24rpx; color: #4a6355; margin-top: 10rpx; }

.group { margin: 0 36rpx 24rpx; background: #ffffff; border: 1rpx solid rgba(47,133,90,0.08); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-card); }
.group-title { display:block; padding: 28rpx 28rpx 12rpx; font-size: 24rpx; color: #6b8577; letter-spacing: 3rpx; font-weight: 700; }

.row { display:flex; align-items:center; padding: 28rpx; border-top: 1rpx solid rgba(47,133,90,0.06); }
.row:first-of-type { border-top: none; }
.row-icon { font-size: 42rpx; margin-right: 22rpx; }
.row-main { flex: 1; }
.row-label { display:block; font-size: 30rpx; color: #0d2b1f; font-weight: 600; }
.row-sub { display:block; font-size: 24rpx; color: #4a6355; margin-top: 6rpx; }
.row-arrow { font-size: 36rpx; color: #8a9e92; }

.add-row { background: rgba(34,118,77,0.04); }
.row-label-amber { font-size: 30rpx; color: #1a6b42; font-weight: 700; }

.status { font-size: 22rpx; font-weight: 700; padding: 8rpx 18rpx; border-radius: 999rpx; }
.status.done { color: var(--green); background: var(--green-pale); }
.status.pending { color: var(--amber); background: var(--amber-pale); }

.empty { text-align:center; padding: 32rpx; color: #6b8577; font-size: 26rpx; }
