.container { background: var(--ink); min-height: 100vh; padding-bottom: 80rpx; }
.page-header { padding: 44rpx 32rpx 28rpx; }
.page-title { display:block; font-size: 36rpx; font-weight: 800; color: var(--text); }
.page-subtitle { display:block; font-size: 22rpx; color: var(--text-dim); margin-top: 10rpx; }

.group { margin: 0 24rpx; background: var(--glass); border: 1rpx solid var(--glass-border); border-radius: var(--radius); overflow: hidden; }
.group-title { display:block; padding: 24rpx 24rpx 10rpx; font-size: 24rpx; color: var(--text-faint); letter-spacing: 2rpx; }

.row { display:flex; align-items:center; padding: 24rpx; border-top: 1rpx solid var(--glass-border); }
.row:first-of-type { border-top: none; }
.row-icon { font-size: 40rpx; margin-right: 20rpx; }
.row-main { flex: 1; }
.row-label { display:block; font-size: 28rpx; color: var(--text); font-weight: 600; }
.row-sub { display:block; font-size: 22rpx; color: var(--text-dim); margin-top: 4rpx; }
.row-arrow { font-size: 34rpx; color: var(--text-faint); }

.add-row { background: rgba(245,166,35,0.06); }
.row-label-amber { font-size: 28rpx; color: var(--amber); font-weight: 700; }

.status { font-size: 22rpx; font-weight: 700; padding: 8rpx 16rpx; border-radius: 40rpx; }
.status.done { color: var(--green); background: var(--green-pale); }
.status.pending { color: var(--amber); background: var(--amber-pale); }

.empty { text-align:center; padding: 24rpx; color: var(--text-dim); font-size: 24rpx; }
