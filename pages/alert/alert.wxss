/* pages/alert/alert.wxss */

.container   { background: #f2f9f4; min-height: 100vh; padding-bottom: 140rpx; }
.filter-bar  { white-space: nowrap; padding: 0 36rpx 28rpx; }
.filter-tag  { display: inline-block; padding: 14rpx 32rpx; border-radius: 999rpx; font-size: 26rpx; color: #4a6355; background: #ffffff; border: 1rpx solid rgba(47,133,90,0.10); margin-right: 16rpx; box-shadow: var(--shadow-card); font-weight: 500; }
.filter-tag.active { background: linear-gradient(135deg, #22764d, #38a169); color: #ffffff; border-color: transparent; font-weight: 700; box-shadow: 0 6rpx 20rpx rgba(34,118,77,0.20); }

.alert-list  { padding: 0 36rpx; }
.alert-card  { border-radius: var(--radius); padding: 32rpx; margin-bottom: 24rpx; border: 1rpx solid rgba(47,133,90,0.08); background: #ffffff; box-shadow: var(--shadow-card); }
.alert-card.level-danger  { border-left: 6rpx solid var(--red); }
.alert-card.level-warning { border-left: 6rpx solid var(--amber); }
.alert-card.level-info    { border-left: 6rpx solid var(--teal); }

.alert-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.level-dot    { width: 14rpx; height: 14rpx; border-radius: 50%; flex-shrink: 0; }
.level-dot.level-danger  { background: var(--red); }
.level-dot.level-warning { background: var(--amber); }
.level-dot.level-info    { background: var(--teal); }
.alert-type   { font-size: 30rpx; font-weight: 700; color: #0d2b1f; flex: 1; }
.alert-time   { font-size: 24rpx; color: #6b8577; }

.alert-content { font-size: 28rpx; color: #4a6355; line-height: 1.7; display: block; }
.alert-loc     { font-size: 24rpx; color: var(--teal); margin-top: 12rpx; display: block; }

.alert-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.btn-sm { flex: 1; padding: 16rpx 0; font-size: 26rpx; border-radius: var(--radius); }

.empty-wrap { text-align: center; padding: 120rpx 0; }
.empty-text { font-size: 32rpx; color: #6b8577; }
