/* pages/location/location.wxss */

.container { background: #f2f9f4; min-height: 100vh; padding-bottom: 140rpx; }
.map-wrap   { position: relative; }
.map-view   { width: 100%; height: 520rpx; }
.map-refresh-btn {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(16rpx);
  border: 1rpx solid rgba(47,133,90,0.08);
  box-shadow: var(--shadow-float);
}
.map-refresh-btn.disabled { opacity: 0.7; }
.map-refresh-icon { font-size: 30rpx; }
.map-refresh-text { font-size: 26rpx; color: var(--text); font-weight: 600; }
.section-wrap { padding: 0 36rpx; margin-top: 28rpx; }

.card-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.card-title  { font-size: 32rpx; font-weight: 800; color: #0d2b1f; }
.addr-text   { font-size: 32rpx; font-weight: 700; color: #0d2b1f; display: block; }
.addr-detail { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 14rpx; }
.addr-chip   {
  font-size: 22rpx;
  color: var(--teal);
  background: var(--teal-pale);
  border: 1rpx solid rgba(47,158,132,0.14);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
}
.time-text   { font-size: 24rpx; color: var(--text-dim); margin-top: 12rpx; display: block; }
.relocate-btn {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #22764d 0%, #38a169 100%);
  border-radius: var(--radius);
  padding: 26rpx 0;
  box-shadow: 0 12rpx 28rpx rgba(34,118,77,0.22);
}
.relocate-btn-text { color: #ffffff; font-size: 30rpx; font-weight: 700; letter-spacing: 1rpx; }

/* 围栏 */
.fence-row   { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid var(--glass-border); }
.fence-row:last-of-type { border-bottom: none; }
.fence-name  { font-size: 30rpx; color: var(--text); display: block; }
.fence-range { font-size: 24rpx; color: var(--text-dim); margin-top: 6rpx; display: block; }
.fence-status.on { color: var(--green); font-size: 26rpx; }
.fence-add   { text-align: center; color: #1a6b42; font-size: 28rpx; font-weight: 600; padding: 24rpx 0; border: 2rpx dashed rgba(47,133,90,0.20); border-radius: var(--radius); margin-top: 16rpx; background: rgba(255,255,255,0.8); }

/* 轨迹时间线 */
.traj-item   { display: flex; align-items: flex-start; position: relative; padding-bottom: 28rpx; }
.traj-dot    { width: 22rpx; height: 22rpx; border-radius: 50%; margin-right: 24rpx; flex-shrink: 0; margin-top: 6rpx; }
.traj-dot.start   { background: var(--green); }
.traj-dot.normal  { background: var(--teal); }
.traj-dot.warning { background: var(--amber); }
.traj-dot.current { background: var(--amber); box-shadow: 0 0 0 6rpx var(--amber-pale); }
.traj-body   { flex: 1; }
.traj-time   { font-size: 24rpx; color: var(--text-dim); display: block; }
.traj-addr   { font-size: 30rpx; color: var(--text); display: block; margin-top: 6rpx; }
.traj-note   { font-size: 24rpx; color: var(--text-dim); display: block; margin-top: 6rpx; }
