/* pages/location/location.wxss */

.container { background: var(--ink); min-height: 100vh; padding-bottom: 120rpx; }
.map-view   { width: 100%; height: 480rpx; }
.section-wrap { padding: 0 32rpx; margin-top: 24rpx; }

.card-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.card-title  { font-size: 28rpx; font-weight: 600; color: var(--text); }
.addr-text   { font-size: 30rpx; font-weight: 600; color: var(--text); display: block; }
.time-text   { font-size: 22rpx; color: var(--text-dim); margin-top: 6rpx; display: block; }

/* 围栏 */
.fence-row   { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--glass-border); }
.fence-row:last-of-type { border-bottom: none; }
.fence-name  { font-size: 28rpx; color: var(--text); display: block; }
.fence-range { font-size: 22rpx; color: var(--text-dim); margin-top: 4rpx; display: block; }
.fence-status.on { color: var(--green); font-size: 24rpx; }
.fence-add   { text-align: center; color: var(--amber); font-size: 26rpx; padding: 20rpx 0; border: 1rpx dashed rgba(245,166,35,0.4); border-radius: var(--radius-sm); margin-top: 12rpx; }

/* 轨迹时间线 */
.traj-item   { display: flex; align-items: flex-start; position: relative; padding-bottom: 24rpx; }
.traj-dot    { width: 20rpx; height: 20rpx; border-radius: 50%; margin-right: 24rpx; flex-shrink: 0; margin-top: 6rpx; }
.traj-dot.start   { background: var(--green); }
.traj-dot.normal  { background: var(--teal); }
.traj-dot.warning { background: var(--amber); }
.traj-dot.current { background: var(--amber); box-shadow: 0 0 0 6rpx var(--amber-pale); }
.traj-body   { flex: 1; }
.traj-time   { font-size: 22rpx; color: var(--text-dim); display: block; }
.traj-addr   { font-size: 28rpx; color: var(--text); display: block; margin-top: 4rpx; }
.traj-note   { font-size: 22rpx; color: var(--amber); display: block; margin-top: 4rpx; }
