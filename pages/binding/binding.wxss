/* pages/binding/binding.wxss */

.container { background: #f2f9f4; min-height: 100vh; padding-bottom: 80rpx; }

.loading-card,
.self-card,
.linked-actions {
  margin: 0 36rpx 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
}

.loading-card {
  padding: 36rpx 28rpx;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-dim);
}

.self-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
}

.self-avatar {
  font-size: 68rpx;
  flex-shrink: 0;
}

.self-info {
  flex: 1;
}

.self-name,
.self-role,
.self-phone {
  display: block;
}

.self-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.self-role {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--amber);
}

.self-phone {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-dim);
}

.copy-btn,
.minor-btn {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  border: 1rpx solid rgba(245,166,35,0.32);
}

.copy-btn {
  color: var(--amber);
  background: var(--amber-pale);
}

.copy-btn.large {
  margin-top: 12rpx;
}

.note-input {
  width: 100%;
  height: 80rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: var(--text);
  background: var(--ink-2);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
}

.linked-actions {
  padding: 20rpx 28rpx;
  display: flex;
  justify-content: flex-end;
}

.minor-btn {
  color: var(--text-dim);
  background: var(--ink-2);
  border-color: var(--glass-border);
}

/* ── 状态横幅 ─────────────────────────────────── */
.status-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 36rpx 28rpx;
  padding: 22rpx 28rpx;
  border-radius: var(--radius);
  border: 1rpx solid;
}
.status-bound   { background: var(--green-pale);  border-color: rgba(93,217,127,0.3);  }
.status-unbound { background: var(--amber-pale);  border-color: rgba(245,166,35,0.3);  }
.status-icon  { font-size: 32rpx; }
.status-text  { font-size: 26rpx; font-weight: 700; color: var(--text); }

/* ── 已绑定：关联对象卡 ──────────────────────── */
.linked-card {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  margin: 0 36rpx 16rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-card);
}
.linked-avatar { font-size: 72rpx; flex-shrink: 0; }
.linked-info   { flex: 1; }
.linked-name   { display: block; font-size: 36rpx; font-weight: 700; color: var(--text); }
.linked-role   { display: block; font-size: 22rpx; color: var(--teal); margin-top: 6rpx; }
.linked-phone  { display: block; font-size: 22rpx; color: var(--text-dim); margin-top: 4rpx; }
.linked-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}
.linked-badge  {
  font-size: 20rpx; padding: 8rpx 18rpx;
  border-radius: 40rpx;
  background: var(--green-pale); color: var(--green);
  border: 1rpx solid rgba(93,217,127,0.3);
  font-weight: 600; flex-shrink: 0;
}

/* 绑定时间 */
.bind-meta { margin: 0 36rpx 24rpx; }
.bind-meta-text { font-size: 22rpx; color: var(--text-faint); }

/* ── 功能说明列表 ────────────────────────────── */
.feature-list {
  margin: 0 36rpx 32rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  padding: 28rpx 32rpx;
  box-shadow: var(--shadow-card);
}
.feature-title { display: block; font-size: 26rpx; font-weight: 700; color: var(--text-dim); margin-bottom: 16rpx; }
.feature-item  { display: flex; align-items: center; gap: 16rpx; padding: 10rpx 0; }
.fi-icon { font-size: 28rpx; }
.fi-text { font-size: 26rpx; color: var(--text); }

/* 解绑按钮 */
.unbind-btn {
  margin: 0 36rpx;
  background: rgba(239,68,68,0.06);
  border: 1rpx solid rgba(239,68,68,0.14);
  border-radius: var(--radius);
  padding: 30rpx;
  text-align: center;
}
.unbind-text { font-size: 26rpx; color: var(--red); font-weight: 600; }

/* ── 未绑定：引导步骤 ────────────────────────── */
.guide-card {
  margin: 0 36rpx 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
}
.guide-title { display: block; font-size: 26rpx; font-weight: 700; color: var(--text); margin-bottom: 16rpx; }
.guide-step  { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 12rpx; }
.step-num    { font-size: 24rpx; color: var(--amber); font-weight: 700; flex-shrink: 0; }
.step-text   { font-size: 24rpx; color: var(--text-dim); line-height: 1.5; }

/* 输入区 */
.input-card {
  margin: 0 36rpx 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
}
.input-label { display: block; font-size: 24rpx; color: var(--text-dim); margin-bottom: 16rpx; }
.phone-row {
  display: flex;
  align-items: center;
  background: var(--ink-2);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-bottom: 16rpx;
}
.phone-prefix {
  padding: 0 20rpx;
  height: 80rpx;
  display: flex; align-items: center;
  border-right: 1rpx solid var(--glass-border);
  font-size: 28rpx; color: var(--text-dim);
}
.phone-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: var(--text);
}
.ph { color: var(--text-faint); }
.err-tip { font-size: 22rpx; color: var(--red); margin-bottom: 16rpx; }
.bind-btn {
  background: linear-gradient(135deg, #22764d 0%, #38a169 100%);
  border-radius: var(--radius);
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(34,118,77,0.22);
  letter-spacing: 1rpx;
}
.bind-btn.disabled { opacity: 0.5; }

/* ── 老人端等待卡 ────────────────────────────── */
.waiting-card {
  margin: 0 36rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  padding: 52rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
}
.waiting-icon  { font-size: 80rpx; }
.waiting-title { font-size: 34rpx; font-weight: 700; color: var(--text); }
.waiting-desc  { font-size: 26rpx; color: var(--text-dim); line-height: 1.6; }
.waiting-phone {
  font-size: 30rpx; font-weight: 700; color: var(--amber);
  background: var(--amber-pale);
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(245,166,35,0.3);
  margin-top: 8rpx;
}
