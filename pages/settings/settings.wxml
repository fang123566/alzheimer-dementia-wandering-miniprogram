<!-- pages/settings/settings.wxml -->
<!-- 基础设置 -->

<view class="container">
  <view class="page-header">
    <text class="page-title">⚙️ 基础设置</text>
    <text class="page-subtitle">紧急联系人 · 方言 · 预警灵敏度 · 通知</text>
  </view>

  <!-- 紧急联系人 -->
  <view class="setting-group">
    <text class="group-title">📞 紧急联系人</text>
    <view wx:for="{{contacts}}" wx:key="id" class="setting-row" bindtap="editContact" data-id="{{item.id}}">
      <text class="row-icon">{{item.avatar}}</text>
      <view class="row-main">
        <text class="row-label">{{item.relation}} · {{item.name}}</text>
        <text class="row-sub">{{item.phone}} · 优先级 {{item.priority}}</text>
      </view>
      <text class="row-arrow">›</text>
    </view>
    <view class="setting-row add-row" bindtap="addContact">
      <text class="row-icon">＋</text>
      <text class="row-label-amber">添加紧急联系人</text>
    </view>
  </view>

  <!-- 老人信息 -->
  <view class="setting-group">
    <text class="group-title">👴 老人基本信息</text>
    <view class="setting-row" bindtap="editElderly">
      <text class="row-icon">🪪</text>
      <view class="row-main">
        <text class="row-label">姓名 / 年龄</text>
        <text class="row-sub">{{elderly.name}} · {{elderly.age}}岁</text>
      </view>
      <text class="row-arrow">›</text>
    </view>
    <view class="setting-row" bindtap="editDialect">
      <text class="row-icon">🗣️</text>
      <view class="row-main">
        <text class="row-label">老人方言</text>
        <text class="row-sub">{{settings.dialect}}</text>
      </view>
      <text class="row-arrow">›</text>
    </view>
    <view class="setting-row" bindtap="editSpeed">
      <text class="row-icon">🔊</text>
      <view class="row-main">
        <text class="row-label">语音播报语速</text>
        <text class="row-sub">{{settings.speechSpeed}}</text>
      </view>
      <text class="row-arrow">›</text>
    </view>
  </view>

  <!-- 预警设置 -->
  <view class="setting-group">
    <text class="group-title">🛡️ 预警设置</text>
    <view class="setting-row" bindtap="editSensitivity">
      <text class="row-icon">🎚️</text>
      <view class="row-main">
        <text class="row-label">预警灵敏度</text>
        <text class="row-sub">{{settings.sensitivity}}</text>
      </view>
      <text class="row-arrow">›</text>
    </view>
    <view class="setting-row">
      <text class="row-icon">📳</text>
      <view class="row-main">
        <text class="row-label">通知方式</text>
        <text class="row-sub">{{settings.notifyMethod}}</text>
      </view>
      <text class="row-arrow">›</text>
    </view>
    <view class="setting-row">
      <text class="row-icon">🌙</text>
      <view class="row-main">
        <text class="row-label">夜间静音模式</text>
        <text class="row-sub">22:00 – 06:00</text>
      </view>
      <switch checked="{{settings.nightMode}}" bindchange="toggleNightMode" color="#f5a623"/>
    </view>
    <view class="setting-row" bindtap="editFence">
      <text class="row-icon">🔵</text>
      <view class="row-main">
        <text class="row-label">安全围栏管理</text>
        <text class="row-sub">家 · 500m｜公园 · 300m</text>
      </view>
      <text class="row-arrow">›</text>
    </view>
  </view>

  <!-- 防诈关键词 -->
  <view class="setting-group">
    <text class="group-title">🛡️ 防诈关键词库</text>
    <view class="keyword-wrap">
      <view wx:for="{{fraudKeywords}}" wx:key="index" class="kw-tag">{{item}}</view>
      <view class="kw-tag kw-add" bindtap="addKeyword">＋ 自定义</view>
    </view>
  </view>

  <!-- 家庭组 -->
  <view class="setting-group">
    <text class="group-title">👥 家庭组</text>
    <view class="setting-row">
      <text class="row-icon">🏠</text>
      <view class="row-main">
        <text class="row-label">{{family.name}}</text>
        <text class="row-sub">{{family.members}} 名成员</text>
      </view>
      <text class="row-arrow">›</text>
    </view>
    <view class="setting-row">
      <text class="row-icon">📱</text>
      <view class="row-main">
        <text class="row-label">老人设备绑定</text>
        <text class="row-sub row-sub-green">已绑定</text>
      </view>
      <text class="row-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-wrap" bindtap="logout">
    <text class="logout-text">退出登录</text>
  </view>

  <!-- 关于 -->
  <view class="about-wrap">
    <text class="about-text">守护·陪伴 v1.0.0</text>
    <text class="about-sub">关爱老人，科技守护</text>
  </view>

</view>
