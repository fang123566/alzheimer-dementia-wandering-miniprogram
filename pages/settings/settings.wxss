/* pages/settings/settings.wxss */

.container   { background: #f2f9f4; min-height: 100vh; padding-bottom: 100rpx; }

/* 分组 */
.setting-group { margin: 0 36rpx 28rpx; background: #ffffff; border: 1rpx solid rgba(47,133,90,0.08); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-card); }
.group-title   { display: block; font-size: 24rpx; color: #6b8577; letter-spacing: 3rpx; font-weight: 700; padding: 32rpx 32rpx 16rpx; border-bottom: 1rpx solid rgba(47,133,90,0.06); }

/* 行 */
.setting-row   { display: flex; align-items: center; padding: 32rpx; border-bottom: 1rpx solid rgba(47,133,90,0.06); }
.setting-row:last-child { border-bottom: none; }
.row-icon      { font-size: 44rpx; margin-right: 22rpx; flex-shrink: 0; }
.row-main      { flex: 1; }
.row-label     { font-size: 32rpx; color: var(--text); display: block; font-weight: 700; }
.row-label-amber { font-size: 32rpx; color: var(--amber); font-weight: 700; }
.row-sub       { font-size: 26rpx; color: #4a6355; display: block; margin-top: 8rpx; }
.row-sub-green { color: var(--green); }
.row-arrow     { font-size: 36rpx; color: #8a9e92; }
.add-row       { background: var(--amber-pale); }

/* 关键词标签 */
.keyword-wrap  { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 28rpx 32rpx 32rpx; }
.kw-tag        { font-size: 26rpx; padding: 12rpx 24rpx; border-radius: 999rpx; background: rgba(239,68,68,0.07); color: #dc2626; border: 1rpx solid rgba(239,68,68,0.14); font-weight: 500; }
.kw-add        { background: rgba(34,118,77,0.08); color: #1a6b42; border-color: rgba(34,118,77,0.14); }

/* 退出登录 */
.logout-wrap {
  margin: 0 36rpx 40rpx;
  background: rgba(239,68,68,0.06);
  border: 1rpx solid rgba(239,68,68,0.14);
  border-radius: var(--radius);
  padding: 32rpx;
  text-align: center;
}
.logout-text { font-size: 32rpx; font-weight: 700; color: #dc2626; }

/* 关于 */
.about-wrap  { text-align: center; padding: 52rpx 0 0; }
.about-text  { display: block; font-size: 28rpx; color: #6b8577; }
.about-sub   { display: block; font-size: 24rpx; color: #8a9e92; margin-top: 8rpx; }
