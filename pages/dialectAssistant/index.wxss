.container { padding: 20rpx; background: #f5f5f5; min-height: 100vh; }
.card { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05); }
.title { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; }

.record-btn {
  width: 200rpx; height: 200rpx; border-radius: 50%; background: #07c160;
  color: #fff; display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; margin: 0 auto 30rpx;
}
.record-btn.recording { background: #ff4d4f; animation: pulse 1s infinite; }
@keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }

.text-area {
  min-height: 150rpx; background: #f9f9f9; border-radius: 8rpx;
  padding: 20rpx; font-size: 32rpx; color: #333; margin-bottom: 20rpx;
}

.accent-select, .voice-select {
  display: flex; align-items: center; font-size: 28rpx; color: #666; margin-bottom: 20rpx;
}
.picker { margin-left: 10rpx; padding: 10rpx 20rpx; background: #f0f0f0; border-radius: 8rpx; }

.input-area {
  width: 100%; min-height: 150rpx; background: #f9f9f9; border-radius: 8rpx;
  padding: 20rpx; font-size: 32rpx; color: #333; border: none;
}

.tts-btn {
  width: 100%; height: 80rpx; background: #1677ff; color: #fff;
  border-radius: 8rpx; font-size: 32rpx; border: none; margin-top: 20rpx;
}

.phrase-list { display: flex; flex-wrap: wrap; gap: 20rpx; }
.phrase-item {
  padding: 15rpx 30rpx; background: #e6f7ff;
  border-radius: 8rpx; font-size: 28rpx; color: #1677ff;
}