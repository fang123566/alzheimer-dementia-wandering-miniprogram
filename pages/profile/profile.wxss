/* pages/profile/profile.wxss */

.container { background: var(--ink); min-height: 100vh; padding-bottom: 140rpx; }

/* ── 用户信息卡 ─────────────────────────────── */
.user-card {
  background: linear-gradient(135deg, #1a2d42 0%, #243d57 100%);
  padding: 60rpx 40rpx 48rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  border-bottom: 1rpx solid var(--glass-border);
}
.avatar-wrap { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.avatar-circle {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  background: var(--amber-pale);
  border: 3rpx solid var(--amber);
  display: flex; align-items: center; justify-content: center;
}
.avatar-emoji { font-size: 64rpx; }
.badge-role {
  font-size: 20rpx; padding: 6rpx 16rpx;
  border-radius: 40rpx; font-weight: 600;
  margin-top: 8rpx;
}
.badge-family {
  background: var(--amber-pale); color: var(--amber);
  border: 1rpx solid rgba(245,166,35,0.3);
}
.badge-elderly {
  background: var(--teal-pale); color: var(--teal);
  border: 1rpx solid rgba(62,207,207,0.3);
}
.user-info { flex: 1; }
.user-name  { display: block; font-size: 40rpx; font-weight: 700; color: var(--text); }
.user-phone { display: block; font-size: 24rpx; color: var(--text-dim); margin-top: 8rpx; }

/* ── 统计行 ──────────────────────────────────── */
.stat-row {
  display: flex;
  background: var(--ink-2);
  border-bottom: 1rpx solid var(--glass-border);
  padding: 28rpx 0;
}
.stat-item  { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stat-num   { font-size: 44rpx; font-weight: 700; color: var(--amber); }
.stat-label { font-size: 22rpx; color: var(--text-dim); margin-top: 6rpx; }
.stat-divider { width: 1rpx; background: var(--glass-border); }

/* ── 分区标题 ────────────────────────────────── */
.section-title {
  font-size: 22rpx; color: var(--text-faint);
  letter-spacing: 2rpx;
  padding: 32rpx 40rpx 12rpx;
}

/* ── 守护对象卡片 ────────────────────────────── */
.elderly-card { margin: 0 32rpx 0; }
.elderly-row  { display: flex; align-items: center; gap: 24rpx; margin-bottom: 16rpx; }
.elderly-avatar { font-size: 60rpx; }
.elderly-info { flex: 1; }
.elderly-name { display: block; font-size: 32rpx; font-weight: 600; color: var(--text); }
.elderly-meta { display: block; font-size: 22rpx; color: var(--text-dim); margin-top: 4rpx; }
.status-dot   { width: 20rpx; height: 20rpx; border-radius: 50%; }
.status-dot.safe      { background: var(--green); box-shadow: 0 0 0 6rpx var(--green-pale); }
.status-dot.warning   { background: var(--amber); box-shadow: 0 0 0 6rpx var(--amber-pale); }
.status-dot.emergency { background: var(--red);   box-shadow: 0 0 0 6rpx var(--red-pale);   }
.elderly-location { display: flex; align-items: center; gap: 8rpx; }
.location-icon { font-size: 24rpx; }
.location-text { font-size: 24rpx; color: var(--text-dim); }

/* ── 绑定状态圆点 ────────────────────────────────────── */
.bind-status-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 8rpx;
}
.dot-bound   { background: var(--green); box-shadow: 0 0 0 4rpx var(--green-pale); }
.dot-unbound { background: var(--amber); box-shadow: 0 0 0 4rpx var(--amber-pale); }

/* ── 菜单组 ──────────────────────────────────── */
.menu-group {
  margin: 0 32rpx 0;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius);
  overflow: hidden;
}
.menu-row {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid var(--glass-border);
}
.menu-row:last-child { border-bottom: none; }
.menu-icon  { font-size: 40rpx; margin-right: 24rpx; flex-shrink: 0; }
.menu-main  { flex: 1; }
.menu-label { display: block; font-size: 28rpx; color: var(--text); }
.menu-label-red { flex: 1; font-size: 28rpx; color: var(--red); font-weight: 600; }
.menu-sub   { display: block; font-size: 22rpx; color: var(--text-dim); margin-top: 4rpx; }
.menu-arrow { font-size: 36rpx; color: var(--text-faint); }
.menu-badge {
  background: var(--red); border-radius: 20rpx;
  min-width: 36rpx; height: 36rpx;
  display: flex; align-items: center; justify-content: center;
  padding: 0 8rpx; margin-right: 12rpx;
}
.menu-badge-text { font-size: 20rpx; color: #fff; font-weight: 700; }

/* ── 版本号 ──────────────────────────────────── */
.version-tip {
  text-align: center;
  font-size: 20rpx;
  color: var(--text-faint);
  padding: 48rpx 0 16rpx;
}

/* ══════ 老人端专属样式 ══════ */
.e-user-card {
  background: linear-gradient(135deg, #1a2d42 0%, #243d57 100%);
  padding: 60rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--glass-border);
}
.e-avatar-circle {
  width: 160rpx; height: 160rpx;
  border-radius: 50%;
  background: var(--teal-pale);
  border: 4rpx solid var(--teal);
  display: flex; align-items: center; justify-content: center;
}
.e-avatar-emoji { font-size: 88rpx; }
.e-user-name    { font-size: 52rpx; font-weight: 800; color: var(--text); }
.e-user-sub     { font-size: 26rpx; color: var(--text-dim); }

/* 分区标题（老人端大字） */
.e-section-title {
  font-size: 30rpx; font-weight: 700;
  color: var(--text-dim);
  padding: 36rpx 40rpx 16rpx;
  letter-spacing: 2rpx;
}

/* 联系人卡片 */
.e-contact-card {
  display: flex;
  align-items: center;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius);
  margin: 0 32rpx 20rpx;
  padding: 28rpx 28rpx;
  gap: 24rpx;
}
.e-contact-avatar { font-size: 64rpx; }
.e-contact-info   { flex: 1; }
.e-contact-name   { display: block; font-size: 36rpx; font-weight: 700; color: var(--text); }
.e-contact-relation { display: block; font-size: 26rpx; color: var(--text-dim); margin-top: 6rpx; }
.e-call-btn {
  display: flex; flex-direction: column; align-items: center;
  background: var(--green-pale);
  border: 1rpx solid rgba(93,217,127,0.3);
  border-radius: var(--radius-sm);
  padding: 16rpx 24rpx;
  gap: 6rpx;
}
.e-call-icon { font-size: 40rpx; }
.e-call-text { font-size: 22rpx; color: var(--green); font-weight: 600; }
.e-empty-tip { text-align: center; color: var(--text-dim); font-size: 28rpx; padding: 24rpx; }

/* 今日提醒 */
.e-reminder-card {
  margin: 0 32rpx 0;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius);
  overflow: hidden;
}
.e-reminder-row {
  display: flex; align-items: center; gap: 20rpx;
  padding: 28rpx;
  border-bottom: 1rpx solid var(--glass-border);
}
.e-reminder-row:last-child { border-bottom: none; }
.e-reminder-icon  { font-size: 44rpx; }
.e-reminder-info  { flex: 1; }
.e-reminder-title { display: block; font-size: 30rpx; font-weight: 600; color: var(--text); }
.e-reminder-time  { display: block; font-size: 24rpx; color: var(--text-dim); margin-top: 4rpx; }
.e-reminder-done    { font-size: 22rpx; color: var(--green); font-weight: 600; padding: 8rpx 16rpx; background: var(--green-pale); border-radius: 40rpx; }
.e-reminder-pending { font-size: 22rpx; color: var(--amber); font-weight: 600; padding: 8rpx 16rpx; background: var(--amber-pale); border-radius: 40rpx; }

/* 功能四宫格 */
.e-func-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 0 32rpx;
}
.e-func-item {
  display: flex; flex-direction: column; align-items: center;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius);
  padding: 36rpx 20rpx;
  gap: 16rpx;
}
.e-func-icon { font-size: 56rpx; }
.e-func-text { font-size: 28rpx; color: var(--text); font-weight: 600; }

/* 退出按钮 */
.e-logout-btn {
  margin: 40rpx 32rpx 0;
  background: var(--red-pale);
  border: 1rpx solid rgba(255,92,92,0.25);
  border-radius: var(--radius);
  padding: 30rpx;
  text-align: center;
}
.e-logout-text { font-size: 30rpx; font-weight: 600; color: var(--red); }
.e-cancel-btn {
  margin-top: 24rpx;
  background: rgba(255,92,92,0.08);
}
