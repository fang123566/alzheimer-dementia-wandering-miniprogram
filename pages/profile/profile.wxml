<!-- pages/profile/profile.wxml -->

<view class="container">

  <!-- ══════════ 家属端 ══════════ -->
  <block wx:if="{{role === 'family'}}">

    <!-- 用户信息卡 -->
    <view class="user-card">
      <view class="avatar-wrap">
        <view class="avatar-circle"><text class="avatar-emoji">👨‍👩‍👧</text></view>
        <view class="badge-role badge-family">家属端</view>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.name || '用户'}}</text>
        <text class="user-phone">{{userInfo.phone || ''}}</text>
      </view>
    </view>

    <!-- 统计行 -->
    <view class="stat-row">
      <view class="stat-item">
        <text class="stat-num">{{stats.unreadAlerts}}</text>
        <text class="stat-label">未读预警</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.totalAlerts}}</text>
        <text class="stat-label">累计预警</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.chatCount}}</text>
        <text class="stat-label">AI对话次</text>
      </view>
    </view>

    <!-- 守护对象 -->
    <view class="section-title">守护对象</view>
    <view class="card elderly-card">
      <view class="elderly-row">
        <view class="elderly-avatar-wrap"><text class="elderly-avatar">👴</text></view>
        <view class="elderly-info">
          <text class="elderly-name">{{elderlyInfo.name}}</text>
          <text class="elderly-meta">{{elderlyInfo.age}} 岁 · 设备已绑定</text>
        </view>
        <view class="status-dot {{locationStatus}}"></view>
      </view>
      <view class="elderly-location">
        <text class="location-icon">📍</text>
        <text class="location-text">{{currentLocation.address || '获取中…'}}</text>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="section-title">功能管理</view>
    <view class="menu-group">
      <view class="menu-row" bindtap="goBinding">
        <text class="menu-icon">🔗</text>
        <view class="menu-main">
          <text class="menu-label">账号关联</text>
          <text class="menu-sub">{{binding ? '已关联：' + binding.linkedUser.name : '未关联老人账号'}}</text>
        </view>
        <view class="bind-status-dot {{binding ? 'dot-bound' : 'dot-unbound'}}"></view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="goSettings">
        <text class="menu-icon">⚙️</text>
        <view class="menu-main"><text class="menu-label">基础设置</text><text class="menu-sub">联系人 · 围栏 · 方言</text></view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="goAlert">
        <text class="menu-icon">🔔</text>
        <view class="menu-main"><text class="menu-label">预警中心</text><text class="menu-sub">查看全部预警记录</text></view>
        <view class="menu-badge" wx:if="{{stats.unreadAlerts > 0}}"><text class="menu-badge-text">{{stats.unreadAlerts}}</text></view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="goMemory">
        <text class="menu-icon">📸</text>
        <view class="menu-main"><text class="menu-label">记忆相册</text><text class="menu-sub">照片 · AI记忆辅助</text></view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="goLocation">
        <text class="menu-icon">🗺️</text>
        <view class="menu-main"><text class="menu-label">实时位置</text><text class="menu-sub">轨迹 · 安全围栏</text></view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="section-title">账号</view>
    <view class="menu-group">
      <view class="menu-row" bindtap="logout">
        <text class="menu-icon">🚪</text>
        <text class="menu-label-red">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="version-tip">守护·陪伴 v1.0.0 · 关爱老人，科技守护</view>

  </block>

  <!-- ══════════ 老人端 ══════════ -->
  <block wx:else>

    <!-- 老人信息卡（大字体） -->
    <view class="e-user-card">
      <view class="e-avatar-circle"><text class="e-avatar-emoji">👴</text></view>
      <text class="e-user-name">{{userInfo.name || '用户'}}</text>
      <view class="badge-role badge-elderly">老人端</view>
      <text class="e-user-sub">守护·陪伴 为您服务</text>
    </view>

    <!-- 紧急联系人（一键拨打） -->
    <view class="e-section-title">紧急联系人</view>
    <view wx:for="{{contacts}}" wx:key="id" class="e-contact-card" bindtap="callContact" data-phone="{{item.phone}}" data-name="{{item.name}}">
      <view class="e-contact-avatar">{{item.avatar || '👤'}}</view>
      <view class="e-contact-info">
        <text class="e-contact-name">{{item.name}}</text>
        <text class="e-contact-relation">{{item.relation}}</text>
      </view>
      <view class="e-call-btn">
        <text class="e-call-icon">📞</text>
        <text class="e-call-text">拨打</text>
      </view>
    </view>
    <view wx:if="{{contacts.length === 0}}" class="e-empty-tip">暂无紧急联系人，请家属在设置中添加</view>

    <!-- 今日提醒 -->
    <view class="e-section-title">今日提醒</view>
    <view class="e-reminder-card">
      <view class="e-reminder-row">
        <text class="e-reminder-icon">💊</text>
        <view class="e-reminder-info">
          <text class="e-reminder-title">早上用药提醒</text>
          <text class="e-reminder-time">每日 08:00</text>
        </view>
        <view class="e-reminder-done">已提醒</view>
      </view>
      <view class="e-reminder-row">
        <text class="e-reminder-icon">🚶</text>
        <view class="e-reminder-info">
          <text class="e-reminder-title">下午散步时间</text>
          <text class="e-reminder-time">每日 15:00</text>
        </view>
        <view class="e-reminder-pending">待提醒</view>
      </view>
    </view>

    <!-- 常用功能 -->
    <view class="e-section-title">常用功能</view>
    <view class="e-func-grid">
      <view class="e-func-item" bindtap="goChat">
        <text class="e-func-icon">🤖</text>
        <text class="e-func-text">AI 陪聊</text>
      </view>
      <view class="e-func-item" bindtap="goDialect">
        <text class="e-func-icon">🗣️</text>
        <text class="e-func-text">方言助手</text>
      </view>
      <view class="e-func-item" bindtap="goMemory">
        <text class="e-func-icon">📸</text>
        <text class="e-func-text">记忆相册</text>
      </view>
      <view class="e-func-item" bindtap="goSettings">
        <text class="e-func-icon">⚙️</text>
        <text class="e-func-text">设置</text>
      </view>
    </view>

    <!-- 账号关联入口 -->
    <view class="e-section-title">账号</view>
    <view class="e-contact-card" bindtap="goBinding" style="margin-bottom:0">
      <view class="e-contact-avatar">🔗</view>
      <view class="e-contact-info">
        <text class="e-contact-name">账号关联</text>
        <text class="e-contact-relation">{{binding ? '已关联家属：' + binding.linkedUser.name : '暂无家属关联'}}</text>
      </view>
      <view class="e-call-btn" style="background:var(--amber-pale);border-color:rgba(245,166,35,0.3)">
        <text class="e-call-icon">›</text>
        <text class="e-call-text" style="color:var(--amber)">查看</text>
      </view>
    </view>

    <!-- 退出 -->
    <view class="e-logout-btn" bindtap="logout">
      <text class="e-logout-text">退出登录</text>
    </view>

    <view class="version-tip">守护·陪伴 v1.0.0</view>

  </block>

</view>
