/* pages/memory/detail/detail.wxss */
.page-wrap { background: #f7f9fc; min-height: 100vh; padding: 24rpx 24rpx 120rpx; }
.hero-card, .card { background: #fff; border-radius: 24rpx; box-shadow: 0 6rpx 24rpx rgba(15,23,42,0.06); overflow: hidden; margin-bottom: 24rpx; }
.media-box { position: relative; background: #e2e8f0; }
.hero-image, .hero-video { width: 100%; height: 460rpx; display: block; }
.video-box { width: 100%; height: 460rpx; background: #000; }
.media-badge { position: absolute; top: 20rpx; left: 20rpx; padding: 10rpx 20rpx; border-radius: 999rpx; color: #fff; font-size: 22rpx; font-weight: 700; }
.media-badge.image { background: rgba(245,158,11,0.9); }
.media-badge.video { background: rgba(14,165,233,0.9); }
.hero-info { padding: 28rpx; }
.memory-title { display: block; font-size: 36rpx; font-weight: 800; color: #1f2937; }
.memory-meta { display: block; margin-top: 12rpx; font-size: 24rpx; color: #64748b; }
.member-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 18rpx; }
.member-tag { background: #fef3c7; color: #b45309; padding: 8rpx 18rpx; border-radius: 999rpx; font-size: 22rpx; font-weight: 600; }
.card { padding: 28rpx; }
.card-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.card-title { font-size: 30rpx; font-weight: 700; color: #1f2937; }
.card-link { font-size: 24rpx; color: #f59e0b; font-weight: 600; }
.story-text, .voice-text { display: block; color: #475569; font-size: 28rpx; line-height: 1.8; }
.story-textarea { width: 100%; min-height: 220rpx; background: #f8fafc; border: 1rpx solid #e2e8f0; border-radius: 16rpx; padding: 24rpx; box-sizing: border-box; font-size: 28rpx; color: #1f2937; }
.voice-actions, .action-row { display: flex; gap: 20rpx; margin-top: 24rpx; }
.action-row.single { gap: 0; }
.voice-btn, .action-btn { flex: 1; text-align: center; border-radius: 16rpx; padding: 24rpx 0; font-size: 28rpx; font-weight: 700; }
.voice-btn.record { background: linear-gradient(135deg, #f97316, #fb923c); color: #fff; }
.voice-btn.record.recording { background: linear-gradient(135deg, #ef4444, #f87171); }
.voice-btn.play { background: #e0f2fe; color: #0369a1; }
.voice-btn.disabled { opacity: 0.5; }
.action-btn.primary { background: linear-gradient(135deg, #f59e0b, #fbbf24); color: #fff; }
.action-btn.ghost { background: #f1f5f9; color: #64748b; }
.action-btn.danger { background: #fee2e2; color: #dc2626; }
.voice-meta { display: block; margin-top: 16rpx; color: #94a3b8; font-size: 24rpx; }
.loading-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #f7f9fc; }
.loading-text { color: #94a3b8; font-size: 28rpx; }