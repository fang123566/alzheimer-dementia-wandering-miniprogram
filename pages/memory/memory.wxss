/* pages/memory/memory.wxss */

.container { background: var(--ink); min-height: 100vh; padding-bottom: 120rpx; }

.member-bar { white-space: nowrap; padding: 0 32rpx 28rpx; }
.member-chip { display: inline-flex; flex-direction: column; align-items: center; margin-right: 24rpx; }
.member-avatar { width: 88rpx; height: 88rpx; border-radius: 50%; border: 3rpx solid var(--glass-border); }
.member-chip.active .member-avatar { border-color: var(--amber); }
.member-name { font-size: 22rpx; color: var(--text-dim); margin-top: 8rpx; }
.member-chip.active .member-name { color: var(--amber); }

.photo-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4rpx; margin: 0 32rpx 32rpx; }
.photo-item { position: relative; aspect-ratio: 1; overflow: hidden; border-radius: var(--radius-sm); }
.photo-img  { width: 100%; height: 100%; }
.photo-caption { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(transparent, rgba(0,0,0,0.6)); padding: 16rpx 12rpx 12rpx; }
.caption-text  { font-size: 20rpx; color: #fff; display: block; }

.add-photo-btn { margin: 0 32rpx 32rpx; border: 2rpx dashed rgba(245,166,35,0.4); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; gap: 16rpx; padding: 32rpx; }
.add-icon { font-size: 40rpx; color: var(--amber); }
.add-text { font-size: 28rpx; color: var(--amber); }

.memory-hint-card { margin: 0 32rpx; }
.card-title { font-size: 28rpx; font-weight: 600; color: var(--text); margin-bottom: 20rpx; display: block; }
.hint-item  { display: flex; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--glass-border); }
.hint-item:last-child { border-bottom: none; }
.hint-icon  { font-size: 28rpx; flex-shrink: 0; }
.hint-text  { font-size: 26rpx; color: var(--text-dim); line-height: 1.6; }
