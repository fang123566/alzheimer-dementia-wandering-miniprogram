/* pages/aichat/aichat.wxss */

.page-container { 
  background: #f6f8fb; 
  height: 100vh; 
  display: flex; 
  flex-direction: column;
  position: relative;
}

.chat-header { 
  padding: 24rpx 24rpx 20rpx; 
  background: linear-gradient(180deg, #fff7e7 0%, #ffffff 100%); 
  border-bottom: 1rpx solid #eef2f7; 
  flex-shrink: 0;
}

.chat-content {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 140rpx;
}

.bot-info { display: flex; align-items: center; gap: 18rpx; }
.bot-avatar { width: 76rpx; height: 76rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; background: #fff; box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.12); font-size: 42rpx; flex-shrink: 0; }
.bot-text-wrap { flex: 1; min-width: 0; }
.bot-name { font-size: 34rpx; font-weight: 700; color: #1f2937; display: block; }
.bot-status { font-size: 22rpx; color: #16a34a; display: block; margin-top: 6rpx; line-height: 1.5; }
.header-action { padding: 12rpx 22rpx; border-radius: 999rpx; background: #fff; border: 1rpx solid #e5e7eb; color: #64748b; font-size: 24rpx; }

/* 顶部操作按钮组 */
.header-actions { display: flex; gap: 12rpx; align-items: center; }
.header-btn { padding: 12rpx 20rpx; border-radius: 999rpx; background: #fff; border: 1rpx solid #e5e7eb; color: #64748b; font-size: 24rpx; font-weight: 600; }
.header-btn.active { background: #f59e0b; color: #fff; border-color: #f59e0b; }
.capability-bar { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 20rpx; }
.capability-tag { padding: 8rpx 18rpx; border-radius: 999rpx; background: #fff; border: 1rpx solid #fde7b0; color: #b45309; font-size: 22rpx; }
.quick-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14rpx; margin-top: 20rpx; }
.quick-card { background: #ffffff; border-radius: 22rpx; padding: 18rpx 10rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10rpx; box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05); border: 1rpx solid #eef2f7; }
.quick-icon { font-size: 34rpx; }
.quick-label { font-size: 24rpx; color: #334155; font-weight: 600; }
.chat-log { flex: 1; padding: 24rpx; overflow: hidden; }
.welcome-card { background: #ffffff; border-radius: 28rpx; padding: 28rpx; box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05); margin-bottom: 24rpx; }
.welcome-title { display: block; font-size: 34rpx; font-weight: 700; color: #1f2937; }
.welcome-desc { display: block; font-size: 26rpx; line-height: 1.8; color: #64748b; margin-top: 12rpx; }
.suggestion-list { display: flex; flex-wrap: wrap; gap: 14rpx; margin-top: 22rpx; }
.suggestion-chip { padding: 14rpx 22rpx; border-radius: 999rpx; background: #fff7e7; color: #b45309; font-size: 24rpx; border: 1rpx solid #fde7b0; }
.msg-row { display: flex; gap: 16rpx; margin-bottom: 28rpx; align-items: flex-start; }
.msg-row.user { flex-direction: row-reverse; }
.msg-avatar { width: 64rpx; height: 64rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; background: #fff; font-size: 36rpx; box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.06); flex-shrink: 0; }
.msg-body { max-width: 76%; }
.msg-name { font-size: 22rpx; color: #94a3b8; display: block; margin-bottom: 8rpx; }
.msg-row.user .msg-name { text-align: right; }
.msg-time { font-size: 20rpx; color: #cbd5e1; display: block; margin-top: 8rpx; }
.msg-row.user .msg-time { text-align: right; }
.bubble { border-radius: 24rpx; padding: 22rpx 24rpx; border: 1rpx solid #e5e7eb; }
.bubble-text { font-size: 28rpx; line-height: 1.75; color: #334155; display: block; white-space: pre-wrap; word-break: break-word; }
.bubble-bot { background: #ffffff; }
.bubble-user { background: #fff1d6; border-color: #ffd78a; }
.bubble-soothe { background: #ecfeff; border-color: #bae6fd; }
.soothe-tag { font-size: 20rpx; color: #0891b2; display: block; margin-top: 10rpx; }
.bubble-fraud { background: #fff1f2; border-color: #fecdd3; }
.fraud-title { font-size: 24rpx; font-weight: 700; color: #e11d48; display: block; margin-bottom: 8rpx; }
.fraud-tip { font-size: 20rpx; color: #64748b; display: block; margin-top: 10rpx; }
.emotion-note { font-size: 20rpx; color: #f59e0b; display: block; margin-top: 8rpx; }
.message-tip { font-size: 20rpx; color: #94a3b8; display: block; margin-top: 8rpx; }

/* 朗读按钮 */
.speak-btn { display: inline-flex; align-items: center; gap: 8rpx; margin-top: 16rpx; padding: 12rpx 20rpx; border-radius: 999rpx; background: #f0f9ff; color: #0284c7; font-size: 24rpx; border: 1rpx solid #bae6fd; }

/* 语音按钮 */
.voice-btn { width: 80rpx; height: 80rpx; border-radius: 999rpx; background: #f8fafc; border: 1rpx solid #e2e8f0; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 32rpx; }
.voice-btn.recording { background: linear-gradient(135deg, #ef4444, #f87171); color: #fff; border-color: #ef4444; animation: pulse 1s infinite; }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }

/* 底部输入区域 - 固定定位 */
.input-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 120rpx;
  background: #ffffff;
  border-top: 1rpx solid #eef2f7;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
}

.input-bar { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 20rpx; background: #ffffff; }
.input-wrap { flex: 1; background: #f8fafc; border: 1rpx solid #e2e8f0; border-radius: 999rpx; padding: 12rpx 20rpx; min-height: 56rpx; display: flex; align-items: center; }
.text-input { flex: 1; font-size: 28rpx; color: #1f2937; background: transparent; min-height: 32rpx; line-height: 1.3; width: 100%; }
.send-btn { min-width: 100rpx; text-align: center; padding: 12rpx 20rpx; border-radius: 999rpx; background: #e2e8f0; color: #94a3b8; font-size: 26rpx; white-space: nowrap; }
.send-btn.active { background: linear-gradient(135deg, #f59e0b, #fbbf24); color: #fff; font-weight: 700; }
.send-btn.sending { opacity: 0.8; }

/* ========== 老人模式大字号 ========== */

.elderly-mode .bot-avatar { width: 100rpx; height: 100rpx; border-radius: 32rpx; font-size: 52rpx; }
.elderly-mode .bot-name { font-size: 44rpx; }
.elderly-mode .bot-status { font-size: 28rpx; }
.elderly-mode .header-btn { padding: 16rpx 28rpx; font-size: 32rpx; }

.elderly-mode .capability-tag { font-size: 30rpx; padding: 12rpx 24rpx; }
.elderly-mode .quick-card { padding: 24rpx 16rpx; }
.elderly-mode .quick-icon { font-size: 44rpx; }
.elderly-mode .quick-label { font-size: 32rpx; }

.elderly-mode .welcome-title { font-size: 44rpx; }
.elderly-mode .welcome-desc { font-size: 34rpx; }
.elderly-mode .suggestion-chip { font-size: 32rpx; padding: 20rpx 28rpx; }

.elderly-mode .msg-avatar { width: 80rpx; height: 80rpx; border-radius: 24rpx; font-size: 44rpx; }
.elderly-mode .msg-name { font-size: 28rpx; }
.elderly-mode .msg-time { font-size: 24rpx; }

.elderly-mode .bubble { padding: 28rpx 32rpx; }
.elderly-mode .bubble-text { font-size: 36rpx; line-height: 1.8; }
.elderly-mode .bubble .speak-btn { font-size: 32rpx; padding: 16rpx 28rpx; margin-top: 20rpx; }
.elderly-mode .fraud-title { font-size: 32rpx; }
.elderly-mode .fraud-tip,
.elderly-mode .emotion-note,
.elderly-mode .message-tip { font-size: 28rpx; }
.elderly-mode .soothe-tag { font-size: 28rpx; }

.elderly-mode .voice-btn { width: 100rpx; height: 100rpx; font-size: 40rpx; }
.elderly-mode .input-wrap { padding: 20rpx 28rpx; }
.elderly-mode .text-input { font-size: 36rpx; }
.elderly-mode .send-btn { min-width: 160rpx; padding: 20rpx 28rpx; font-size: 36rpx; }
