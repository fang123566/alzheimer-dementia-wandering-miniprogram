/* pages/index/index.wxss */

.container { background: #f2f9f4; min-height: 100vh; padding-bottom: 140rpx; }

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}
.role-badge {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 26rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.badge-family {
  background: var(--amber-pale);
  color: var(--amber);
  border: 1rpx solid rgba(47,133,90,0.18);
}
.badge-elderly {
  background: var(--teal-pale);
  color: var(--teal);
  border: 1rpx solid rgba(47,158,132,0.22);
}

/* ══════ 老人端首页样式 ══════ */
.elderly-home { padding-bottom: 156rpx; }

.e-greeting-block {
  padding: 52rpx 36rpx 40rpx;
  background: linear-gradient(180deg, rgba(34,118,77,0.12) 0%, transparent 100%);
}
.e-greeting {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #0d2b1f;
  letter-spacing: 2rpx;
}
.e-date {
  display: block;
  font-size: 32rpx;
  color: #1a6b42;
  margin-top: 14rpx;
  font-weight: 600;
}

/* 大 SOS 按钮 */
.e-sos-card {
  margin: 0 36rpx 36rpx;
  background: linear-gradient(145deg, #ffffff 0%, #fff5f5 60%, #ffe8e8 100%);
  border: 2rpx solid rgba(239,68,68,0.18);
  border-radius: var(--radius-lg);
  padding: 52rpx 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(239,68,68,0.10), 0 4rpx 12rpx rgba(239,68,68,0.06);
}
.e-sos-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}
.e-sos-icon  { font-size: 100rpx; line-height: 1; }
.e-sos-label { font-size: 52rpx; font-weight: 900; color: #dc2626; letter-spacing: 6rpx; }
.e-sos-hint  { font-size: 26rpx; color: #7a8980; letter-spacing: 1rpx; }

/* 四宫格 */
.e-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin: 0 36rpx 32rpx;
}
.e-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  min-height: 210rpx;
  padding: 40rpx 20rpx;
  gap: 20rpx;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease;
}
.e-grid-call {
  background: linear-gradient(160deg, #f0faf4 0%, #ffffff 100%);
  border-color: rgba(47,133,90,0.14);
}
.e-grid-icon { font-size: 72rpx; line-height: 1; }
.e-grid-text { font-size: 34rpx; font-weight: 700; color: #0d2b1f; letter-spacing: 1rpx; }

/* 位置卡 */
.e-location-card {
  margin: 0 36rpx 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  padding: 36rpx;
  box-shadow: var(--shadow-card);
}
.e-loc-row  { display: flex; align-items: center; gap: 16rpx; }
.e-loc-icon { font-size: 40rpx; flex-shrink: 0; }
.e-loc-info { flex: 1; }
.e-loc-addr { display: block; font-size: 32rpx; color: #0d2b1f; font-weight: 700; line-height: 1.5; }
.e-loc-status { display: block; font-size: 26rpx; color: #4a6355; margin-top: 8rpx; }
.e-loc-refresh-btn {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #22764d 0%, #38a169 100%);
  border-radius: var(--radius);
  padding: 26rpx 0;
  box-shadow: 0 12rpx 28rpx rgba(34,118,77,0.22);
}
.e-loc-refresh-btn.disabled {
  opacity: 0.6;
}
.e-loc-refresh-icon { font-size: 28rpx; }
.e-loc-refresh-text { font-size: 28rpx; color: #ffffff; font-weight: 600; }

/* 设备状态行 */
.e-device-row {
  display: flex;
  margin: 0 36rpx;
  gap: 20rpx;
}
.e-device-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius-sm);
  padding: 26rpx 24rpx;
  box-shadow: var(--shadow-card);
}
.e-device-icon { font-size: 34rpx; }
.e-device-text { font-size: 28rpx; color: #3d5a4c; font-weight: 500; }

/* 状态卡片 */
.section-wrap { padding: 0 36rpx; }
.status-card  { border-left: 6rpx solid #22764d; }
.card-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.card-title { font-size: 34rpx; font-weight: 800; color: #0d2b1f; }
.location-address { font-size: 34rpx; font-weight: 700; color: #0d2b1f; display: block; line-height: 1.5; }
.location-time    { font-size: 26rpx; color: #4a6355; margin-top: 10rpx; display: block; }
.link-text { font-size: 28rpx; color: #1a6b42; font-weight: 600; }
.mt-16 { margin-top: 20rpx; }

/* 统计格子 */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 28rpx;
}
.stat-card {
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  min-height: 190rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: var(--shadow-card);
}
.stat-icon  { font-size: 40rpx; margin-bottom: 14rpx; }
.stat-label { font-size: 26rpx; color: #4a6355; margin-bottom: 10rpx; }
.stat-value { font-size: 44rpx; font-weight: 800; color: #0d2b1f; }
.val-danger { color: var(--red); }
.val-warn   { color: var(--amber); }

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
  margin-top: 28rpx;
}
.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 160rpx;
  padding: 28rpx 0;
  background: #ffffff;
  border: 1rpx solid rgba(47,133,90,0.08);
  border-radius: var(--radius);
  box-shadow: var(--shadow-card);
}
.quick-icon { font-size: 44rpx; }
.quick-text { font-size: 26rpx; color: #3d5a4c; margin-top: 12rpx; font-weight: 600; }

/* SOS */
.sos-card { border: 2rpx solid rgba(239,68,68,0.18); background: linear-gradient(145deg, #ffffff 0%, #fff5f5 100%); border-radius: var(--radius-lg); }
.sos-btn  { display: flex; flex-direction: column; align-items: center; padding: 36rpx 0; }
.sos-icon { font-size: 80rpx; }
.sos-label { font-size: 40rpx; font-weight: 700; color: #dc2626; margin-top: 14rpx; }
.sos-hint  { font-size: 24rpx; color: #7a8980; margin-top: 8rpx; }

/* 预警列表 */
.alert-row  { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid var(--glass-border); }
.alert-row:last-child { border-bottom: none; }
.alert-dot  { width: 18rpx; height: 18rpx; border-radius: 50%; margin-right: 20rpx; flex-shrink: 0; }
.alert-dot.warning { background: var(--amber); }
.alert-dot.danger  { background: var(--red); }
.alert-info { flex: 1; }
.alert-title { font-size: 30rpx; color: #0d2b1f; display: block; font-weight: 700; }
.alert-time  { font-size: 26rpx; color: #4a6355; margin-top: 6rpx; display: block; }
.empty-tip   { text-align: center; font-size: 30rpx; color: #4a6355; padding: 36rpx 0; }
