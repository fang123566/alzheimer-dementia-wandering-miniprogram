/* pages/index/index.wxss */

.container { background: var(--ink); min-height: 100vh; padding-bottom: 120rpx; }

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}
.role-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.badge-family {
  background: var(--amber-pale);
  color: var(--amber);
  border: 1rpx solid rgba(245,166,35,0.3);
}
.badge-elderly {
  background: var(--teal-pale);
  color: var(--teal);
  border: 1rpx solid rgba(62,207,207,0.3);
}

/* ══════ 老人端首页样式 ══════ */
.elderly-home { padding-bottom: 140rpx; }

.e-greeting-block {
  padding: 48rpx 40rpx 32rpx;
  background: linear-gradient(180deg, #1a2d42 0%, transparent 100%);
}
.e-greeting {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: var(--text);
  letter-spacing: 2rpx;
}
.e-date {
  display: block;
  font-size: 30rpx;
  color: var(--amber);
  margin-top: 12rpx;
  font-weight: 500;
}

/* 大 SOS 按钮 */
.e-sos-card {
  margin: 0 32rpx 32rpx;
  background: linear-gradient(135deg, rgba(255,92,92,0.18) 0%, rgba(255,92,92,0.08) 100%);
  border: 3rpx solid rgba(255,92,92,0.4);
  border-radius: var(--radius);
  padding: 40rpx 20rpx;
}
.e-sos-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.e-sos-icon  { font-size: 100rpx; line-height: 1; }
.e-sos-label { font-size: 52rpx; font-weight: 900; color: var(--red); letter-spacing: 4rpx; }
.e-sos-hint  { font-size: 26rpx; color: var(--text-dim); }

/* 四宫格 */
.e-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 0 32rpx 28rpx;
}
.e-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius);
  padding: 40rpx 20rpx;
  gap: 16rpx;
}
.e-grid-call {
  background: var(--green-pale);
  border-color: rgba(93,217,127,0.3);
}
.e-grid-icon { font-size: 64rpx; line-height: 1; }
.e-grid-text { font-size: 32rpx; font-weight: 700; color: var(--text); }

/* 位置卡 */
.e-location-card {
  margin: 0 32rpx 20rpx;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius);
  padding: 28rpx;
}
.e-loc-row  { display: flex; align-items: center; gap: 16rpx; }
.e-loc-icon { font-size: 36rpx; flex-shrink: 0; }
.e-loc-info { flex: 1; }
.e-loc-addr { display: block; font-size: 28rpx; color: var(--text); font-weight: 600; }
.e-loc-status { display: block; font-size: 22rpx; color: var(--text-dim); margin-top: 4rpx; }

/* 设备状态行 */
.e-device-row {
  display: flex;
  margin: 0 32rpx;
  gap: 20rpx;
}
.e-device-item {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 18rpx 20rpx;
}
.e-device-icon { font-size: 28rpx; }
.e-device-text { font-size: 24rpx; color: var(--text-dim); }

/* 状态卡片 */
.section-wrap { padding: 0 32rpx; }
.status-card  { border-left: 6rpx solid var(--green); }
.card-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.card-title { font-size: 28rpx; font-weight: 600; color: var(--text); }
.location-address { font-size: 30rpx; font-weight: 600; color: var(--text); display: block; }
.location-time    { font-size: 22rpx; color: var(--text-dim); margin-top: 6rpx; display: block; }
.link-text { font-size: 24rpx; color: var(--amber); }
.mt-16 { margin-top: 16rpx; }

/* 统计格子 */
.stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.stat-card {
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius);
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
}
.stat-icon  { font-size: 36rpx; margin-bottom: 12rpx; }
.stat-label { font-size: 22rpx; color: var(--text-dim); margin-bottom: 8rpx; }
.stat-value { font-size: 40rpx; font-weight: 700; color: var(--text); }
.val-danger { color: var(--red); }
.val-warn   { color: var(--amber); }

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}
.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
}
.quick-icon { font-size: 36rpx; }
.quick-text { font-size: 20rpx; color: var(--text-dim); margin-top: 8rpx; }

/* SOS */
.sos-card { border: 2rpx solid rgba(255,92,92,0.4); background: var(--red-pale); }
.sos-btn  { display: flex; flex-direction: column; align-items: center; padding: 32rpx 0; }
.sos-icon { font-size: 80rpx; }
.sos-label { font-size: 40rpx; font-weight: 700; color: var(--red); margin-top: 12rpx; }
.sos-hint  { font-size: 22rpx; color: var(--text-dim); margin-top: 8rpx; }

/* 预警列表 */
.alert-row  { display: flex; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid var(--glass-border); }
.alert-row:last-child { border-bottom: none; }
.alert-dot  { width: 16rpx; height: 16rpx; border-radius: 50%; margin-right: 20rpx; flex-shrink: 0; }
.alert-dot.warning { background: var(--amber); }
.alert-dot.danger  { background: var(--red); }
.alert-info { flex: 1; }
.alert-title { font-size: 26rpx; color: var(--text); display: block; }
.alert-time  { font-size: 22rpx; color: var(--text-dim); margin-top: 4rpx; display: block; }
.empty-tip   { text-align: center; font-size: 26rpx; color: var(--text-dim); padding: 32rpx 0; }
