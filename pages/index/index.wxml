<!-- pages/index/index.wxml -->
<!-- 首页 · 实时监控 -->

<view class="container">

  <!-- 顶部问候 & 用户信息 -->
  <view class="page-header">
    <view class="header-row">
      <view>
        <text class="page-title">守护·陪伴</text>
        <text class="page-subtitle">{{greeting}}，{{userInfo.name || '用户'}}</text>
      </view>
      <view class="header-right">
        <view class="role-badge {{role === 'elderly' ? 'badge-elderly' : 'badge-family'}}">
          <text>{{role === 'elderly' ? '👴 老人端' : '👨‍👩‍👧 家属端'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ══════════ 老人端首页（大字体简洁模式） ══════════ -->
  <view class="elderly-home" wx:if="{{role === 'elderly'}}">

    <!-- 时间问候块 -->
    <view class="e-greeting-block">
      <text class="e-greeting">{{greeting}}，{{userInfo.name || '您好'}}</text>
      <text class="e-date">{{currentDate}}</text>
    </view>

    <!-- 大 SOS 按钮 -->
    <view class="e-sos-card" bindlongpress="triggerSOS" bindtap="triggerSOSTap">
      <view class="e-sos-inner">
        <text class="e-sos-icon">🆘</text>
        <text class="e-sos-label">紧急求助</text>
        <text class="e-sos-hint">长按 3 秒发送位置给家人</text>
      </view>
    </view>

    <!-- 四宫格快捷操作 -->
    <view class="e-grid">
      <view class="e-grid-item e-grid-call" bindtap="callEmergency">
        <text class="e-grid-icon">📞</text>
        <text class="e-grid-text">联系家人</text>
      </view>
      <view class="e-grid-item" bindtap="goChat">
        <text class="e-grid-icon">🤖</text>
        <text class="e-grid-text">AI 陪聊</text>
      </view>
      <view class="e-grid-item" bindtap="goDialect">
        <text class="e-grid-icon">🗣️</text>
        <text class="e-grid-text">方言助手</text>
      </view>
      <view class="e-grid-item" bindtap="goMemory">
        <text class="e-grid-icon">📸</text>
        <text class="e-grid-text">记忆相册</text>
      </view>
    </view>

    <!-- 当前位置卡 -->
    <view class="e-location-card">
      <view class="e-loc-row">
        <text class="e-loc-icon">📍</text>
        <view class="e-loc-info">
          <text class="e-loc-addr">{{currentLocation.address || '正在获取位置…'}}</text>
          <text class="e-loc-status">状态：{{statusText}}</text>
        </view>
        <view class="tag {{statusTag}}">{{statusText}}</view>
      </view>
      <view class="e-loc-refresh-btn {{locating ? 'disabled' : ''}}" bindtap="refreshLocation">
        <text class="e-loc-refresh-icon">🔄</text>
        <text class="e-loc-refresh-text">{{locating ? '更新位置中…' : '重新定位'}}</text>
      </view>
    </view>

    <!-- 设备状态 -->
    <view class="e-device-row">
      <view class="e-device-item">
        <text class="e-device-icon">🛡️</text>
        <text class="e-device-text">今日预警 {{stats.alerts}} 次</text>
      </view>
    </view>

  </view>

  <!-- ══════════ 家属端首页 ══════════ -->
  <!-- 实时状态卡片 -->
  <view class="section-wrap" wx:if="{{role === 'family'}}">

    <!-- 位置状态 -->
    <view class="card status-card">
      <view class="card-title-row">
        <text class="card-title">📍 实时位置状态</text>
        <view class="tag {{statusTag}}">{{statusText}}</view>
      </view>
      <view class="location-info">
        <text class="location-address">{{currentLocation.address}}</text>
        <text class="location-time">更新于 {{currentLocation.updatedAt}}</text>
      </view>
      <view class="btn btn-ghost mt-16" bindtap="goLocation">查看轨迹地图 ›</view>
    </view>

    <!-- 数据统计卡片组 -->
    <view class="stat-grid">
      <view class="stat-card">
        <text class="stat-icon">🏠</text>
        <text class="stat-label">离家距离</text>
        <text class="stat-value">{{stats.distance}} m</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">🛡️</text>
        <text class="stat-label">今日预警</text>
        <text class="stat-value {{stats.alerts > 0 ? 'val-warn' : ''}}">{{stats.alerts}} 次</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">🤖</text>
        <text class="stat-label">AI对话</text>
        <text class="stat-value">{{stats.aiChats}} 次</text>
      </view>
    </view>

    <!-- 快捷操作（家属端） -->
    <view class="card" wx:if="{{role === 'family'}}">
      <text class="card-title">🚀 快捷操作</text>
      <view class="quick-actions">
        <view class="quick-btn" bindtap="callEmergency">
          <text class="quick-icon">📞</text>
          <text class="quick-text">紧急呼叫</text>
        </view>
        <view class="quick-btn" bindtap="goAlert">
          <text class="quick-icon">🔔</text>
          <text class="quick-text">预警中心</text>
        </view>
        <view class="quick-btn" bindtap="goMemory">
          <text class="quick-icon">📸</text>
          <text class="quick-text">记忆相册</text>
        </view>
        <view class="quick-btn" bindtap="goSettings">
          <text class="quick-icon">⚙️</text>
          <text class="quick-text">设置</text>
        </view>
      </view>
    </view>

    <!-- 最近预警列表 -->
    <view class="card">
      <view class="card-title-row">
        <text class="card-title">🔔 最近预警</text>
        <text class="link-text" bindtap="goAlert">查看全部</text>
      </view>
      <view wx:for="{{recentAlerts}}" wx:key="id" class="alert-row">
        <view class="alert-dot {{item.level}}"></view>
        <view class="alert-info">
          <text class="alert-title">{{item.title}}</text>
          <text class="alert-time">{{item.time}}</text>
        </view>
      </view>
      <view wx:if="{{recentAlerts.length === 0}}" class="empty-tip">暂无预警，一切正常 ✅</view>
    </view>

  </view>
</view>
