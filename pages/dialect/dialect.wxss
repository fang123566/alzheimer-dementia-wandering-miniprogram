/* pages/dialect/dialect.wxss */

.container { background: var(--ink); min-height: 100vh; padding-bottom: 140rpx; }

/* ── 翻译方向控制栏 ─────────────────────────── */
.control-bar {
  display: flex;
  align-items: center;
  margin: 0 32rpx 24rpx;
  gap: 0;
}
.lang-box {
  flex: 1;
  background: var(--ink-2);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm) 0 0 var(--radius-sm);
  padding: 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.lang-box-right {
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  border-left: none;
}
.lang-label  { font-size: 28rpx; font-weight: 700; color: var(--amber); }
.lang-change { font-size: 20rpx; color: var(--teal); }
.swap-btn {
  width: 80rpx; height: 80rpx;
  background: var(--amber);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.swap-icon { font-size: 36rpx; color: #0d1b2a; font-weight: 700; }

/* ── 输入卡片 ───────────────────────────────── */
.input-card { margin: 0 32rpx 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; color: var(--text); display: block; margin-bottom: 20rpx; }
.card-title-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.link-text  { font-size: 24rpx; color: var(--amber); }

.text-area {
  width: 100%;
  min-height: 160rpx;
  background: var(--ink-2);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 20rpx;
  font-size: 30rpx;
  color: var(--text);
  line-height: 1.6;
  box-sizing: border-box;
}
.ph { color: var(--text-faint); }
.char-count { text-align: right; font-size: 20rpx; color: var(--text-faint); margin-top: 8rpx; }

.action-row { display: flex; gap: 20rpx; margin-top: 24rpx; }
.btn-half   { flex: 1; }
.disabled   { opacity: 0.5; }

/* ── 语音输入按鈕 ───────────────────────────── */
.voice-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--ink-2);
  border: 2rpx dashed var(--glass-border);
  border-radius: var(--radius);
  padding: 36rpx 20rpx;
  margin-bottom: 24rpx;
  gap: 12rpx;
  transition: all 0.2s;
}
.voice-recording {
  background: var(--red-pale);
  border-color: var(--red);
  border-style: solid;
}
.voice-icon  { font-size: 72rpx; line-height: 1; }
.voice-label { font-size: 32rpx; font-weight: 700; color: var(--text); }
.voice-hint  { font-size: 22rpx; color: var(--text-dim); }

/* ── 翻译结果 ──────────────────────────────── */
.result-card { margin: 0 32rpx 24rpx; border-left: 6rpx solid var(--teal); }
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.result-title { font-size: 28rpx; font-weight: 600; color: var(--text); }
.replay-btn {
  font-size: 24rpx; color: var(--teal);
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(62,207,207,0.3);
  border-radius: 40rpx;
  background: var(--teal-pale);
}
.result-text { font-size: 34rpx; color: var(--text); line-height: 1.7; display: block; font-weight: 500; }
.phonetic    { margin-top: 16rpx; }
.phonetic-label { font-size: 22rpx; color: var(--text-dim); }
.phonetic-text  { font-size: 22rpx; color: var(--amber); }

/* ── 分区标题 ───────────────────────────────── */
.section-title {
  font-size: 22rpx; color: var(--text-faint);
  letter-spacing: 2rpx; padding: 8rpx 40rpx 16rpx;
}

/* ── 常用短语 ───────────────────────────────── */
.phrase-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 32rpx 28rpx;
}
.phrase-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
}
.phrase-emoji { font-size: 28rpx; }
.phrase-text  { font-size: 24rpx; color: var(--text); }

/* ── 历史记录 ───────────────────────────────── */
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--glass-border);
}
.history-item:last-child { border-bottom: none; }
.history-body     { flex: 1; }
.history-original { display: block; font-size: 26rpx; color: var(--text); }
.history-arrow    { display: block; font-size: 20rpx; color: var(--text-faint); margin-top: 4rpx; }
.history-result   { display: block; font-size: 22rpx; color: var(--teal); margin-top: 4rpx; }
