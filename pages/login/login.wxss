/* pages/login/login.wxss */

.page {
  min-height: 100vh;
  background: var(--ink);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 60rpx;
  box-sizing: border-box;
}

/* ── 品牌区 ─────────────────────────────── */
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 56rpx;
}
.brand-icon  { font-size: 96rpx; margin-bottom: 16rpx; }
.brand-name  { font-size: 52rpx; font-weight: 800; color: var(--amber); letter-spacing: 4rpx; }
.brand-slogan{ font-size: 24rpx; color: var(--text-dim); margin-top: 10rpx; letter-spacing: 2rpx; }

/* ── 模式切换 ────────────────────────────── */
.mode-switch {
  display: flex;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 6rpx;
  margin-bottom: 40rpx;
  width: 100%;
}
.mode-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: var(--text-dim);
  font-weight: 500;
  transition: all 0.2s;
}
.mode-btn.active {
  background: var(--amber);
  color: #0d1b2a;
  font-weight: 700;
}

/* ── 表单卡片 ────────────────────────────── */
.form-card {
  width: 100%;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius);
  padding: 40rpx 36rpx 36rpx;
  box-sizing: border-box;
}

/* ── 输入字段 ────────────────────────────── */
.field {
  margin-bottom: 32rpx;
}
.field-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}
.field-input {
  width: 100%;
  background: var(--ink-2);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}
.field-input:focus {
  border-color: var(--amber);
}
.ph { color: var(--text-faint); }

/* ── 角色选择 ────────────────────────────── */
.role-title {
  display: block;
  font-size: 24rpx;
  color: var(--text-dim);
  margin-bottom: 20rpx;
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}
.role-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}
.role-card {
  flex: 1;
  background: var(--ink-2);
  border: 2rpx solid var(--glass-border);
  border-radius: var(--radius);
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 0.2s;
}
.role-card.role-active-family {
  border-color: var(--amber);
  background: var(--amber-pale);
}
.role-card.role-active-elderly {
  border-color: var(--teal);
  background: var(--teal-pale);
}
.role-emoji { font-size: 52rpx; margin-bottom: 12rpx; }
.role-name  {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 10rpx;
}
.role-desc  {
  font-size: 20rpx;
  color: var(--text-dim);
  text-align: center;
  line-height: 1.5;
}
.role-check {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--amber);
  color: #0d1b2a;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.role-active-elderly .role-check {
  background: var(--teal);
}

/* ── 错误提示 ────────────────────────────── */
.error-tip {
  background: var(--red-pale);
  border: 1rpx solid rgba(255,92,92,0.25);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
}
.error-text { font-size: 24rpx; color: var(--red); }

/* ── 提交按钮 ────────────────────────────── */
.submit-btn {
  width: 100%;
  background: var(--amber);
  color: #0d1b2a;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  padding: 26rpx 0;
  border-radius: var(--radius-sm);
  letter-spacing: 4rpx;
  margin-bottom: 28rpx;
}
.submit-btn.disabled {
  opacity: 0.6;
}

/* ── 切换提示 ────────────────────────────── */
.switch-tip {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-dim);
}
.switch-link {
  color: var(--amber);
  margin-left: 8rpx;
  font-weight: 600;
}

/* ── 演示账号 ────────────────────────────── */
.demo-tip {
  margin-top: 48rpx;
  text-align: center;
}
.demo-text {
  display: block;
  font-size: 20rpx;
  color: var(--text-faint);
  line-height: 1.8;
}
