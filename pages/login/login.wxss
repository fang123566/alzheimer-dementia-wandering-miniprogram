/* ── 背景装饰 ─────────────────────────────── */
.bg-decoration {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 560rpx;
  z-index: 0;
  pointer-events: none;
}

/* 使用图片作为背景山水（替代原先的 CSS 山峦） */
.bg-mountain-img {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 隐藏原先 CSS 山峦层，避免叠加发丑 */
.mountain-wave-1,
.mountain-wave-2,
.mountain-wave-3,
.mountain-curve-1,
.mountain-curve-2,
.mountain-curve-3,
.mountain-gold-edge,
.mountain-grain {
  display: none;
}

/* 波浪形山峦（参考你给的 HTML：远景淡色波纹 + 三层旋转大波浪 + 金线） */
.mountain-wave-1 {
  position: absolute;
  top: 60rpx;
  left: -10%;
  width: 120%;
  height: 230rpx;
  z-index: 1;
  border-radius: 50%;
  background: linear-gradient(135deg, #a8e3d0 0%, #73b8a3 50%, #4a9d8c 100%);
  transform: rotate(-3deg);
  opacity: 0.9;
  filter: blur(0.6rpx);
}

.mountain-wave-2 {
  position: absolute;
  top: 140rpx;
  left: -10%;
  width: 120%;
  height: 230rpx;
  z-index: 2;
  border-radius: 50%;
  background: linear-gradient(135deg, #86c7b3 0%, #5aa897 50%, #368a7a 100%);
  transform: rotate(2deg);
  opacity: 0.88;
  filter: blur(0.8rpx);
}

.mountain-wave-3 {
  position: absolute;
  top: 220rpx;
  left: -8%;
  width: 115%;
  height: 240rpx;
  z-index: 3;
  border-radius: 50%;
  background: linear-gradient(135deg, #b4e0d0 0%, #92c9b8 50%, #6ab09f 100%);
  transform: rotate(-1deg);
  opacity: 1;
  filter: blur(0.6rpx);
}

/* 近山层顶部：金线描边（纯装饰） */
.mountain-gold-edge {
  position: absolute;
  top: 290rpx; /* 参考 line-3 的 55% 效果，按 bg-decoration 高度微调 */
  left: -10%;
  width: 120%;
  height: 3rpx;
  z-index: 10;
  background: linear-gradient(90deg, transparent 0%, rgba(212, 175, 55, 0.95) 50%, transparent 100%);
  border-radius: 999rpx;
  filter: blur(0.1rpx);
  opacity: 0.95;
  transform: rotate(-0.5deg);
}

/* 起伏曲线层 */
.mountain-curve-1 {
  position: absolute;
  top: 40rpx; /* far-1: 5% */
  left: -25%;
  width: 150%;
  height: 110rpx;
  z-index: 0;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(233, 244, 240, 0.95) 0%, rgba(215, 231, 224, 0.8) 100%);
  opacity: 0.32;
  filter: blur(1.8rpx);
}

.mountain-curve-2 {
  position: absolute;
  top: 120rpx; /* far-2: 15% */
  left: -25%;
  width: 150%;
  height: 110rpx;
  z-index: 0;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(229, 242, 237, 0.92) 0%, rgba(206, 224, 216, 0.78) 100%);
  opacity: 0.28;
  filter: blur(2.2rpx);
}

.mountain-curve-3 {
  position: absolute;
  top: 190rpx; /* far-3: 25% */
  left: -25%;
  width: 150%;
  height: 110rpx;
  z-index: 0;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(236, 247, 243, 0.9) 0%, rgba(214, 232, 222, 0.76) 100%);
  opacity: 0.26;
  filter: blur(2rpx);
}

/* 颗粒噪点层 */
.mountain-grain {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  z-index: 5;
  opacity: 0.22;
  background-image: 
    radial-gradient(circle at 15% 25%, rgba(255,255,255,0.12) 1px, transparent 1px),
    radial-gradient(circle at 35% 45%, rgba(255,255,255,0.08) 1px, transparent 1px),
    radial-gradient(circle at 55% 15%, rgba(255,255,255,0.09) 1px, transparent 1px),
    radial-gradient(circle at 75% 55%, rgba(255,255,255,0.07) 1px, transparent 1px),
    radial-gradient(circle at 25% 75%, rgba(255,255,255,0.08) 1px, transparent 1px),
    radial-gradient(circle at 85% 35%, rgba(255,255,255,0.07) 1px, transparent 1px);
  background-size: 20rpx 20rpx, 25rpx 25rpx, 30rpx 30rpx, 22rpx 22rpx, 18rpx 18rpx, 28rpx 28rpx;
  pointer-events: none;
}

