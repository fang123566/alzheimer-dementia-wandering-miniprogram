<!-- pages/login/login.wxml -->
<view class="page">

  <!-- 顶部品牌区 -->
  <view class="brand">
    <view class="brand-icon">🛡️</view>
    <text class="brand-name">守护·陪伴</text>
    <text class="brand-slogan">关爱老人，科技守护</text>
  </view>

  <!-- 模式切换：登录 / 注册 -->
  <view class="mode-switch">
    <view
      class="mode-btn {{mode === 'login' ? 'active' : ''}}"
      bindtap="setMode" data-m="login"
    >登录</view>
    <view
      class="mode-btn {{mode === 'register' ? 'active' : ''}}"
      bindtap="setMode" data-m="register"
    >注册</view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">

    <!-- 姓名（仅注册） -->
    <view class="field" wx:if="{{mode === 'register'}}">
      <text class="field-label">姓名</text>
      <input
        class="field-input"
        placeholder="请输入真实姓名"
        placeholder-style="color:#94a3b8;font-size:30rpx;"
        value="{{form.name}}"
        bindinput="onInput" data-key="name"
        maxlength="10"
      />
    </view>

    <!-- 手机号 -->
    <view class="field">
      <text class="field-label">手机号</text>
      <input
        class="field-input"
        type="number"
        placeholder="请输入手机号"
        placeholder-style="color:#94a3b8;font-size:30rpx;"
        value="{{form.phone}}"
        bindinput="onInput" data-key="phone"
        maxlength="11"
      />
    </view>

    <!-- 密码 -->
    <view class="field">
      <text class="field-label">密码</text>
      <input
        class="field-input"
        password
        placeholder="{{mode === 'register' ? '请设置密码（6位以上）' : '请输入密码'}}"
        placeholder-style="color:#94a3b8;font-size:30rpx;"
        value="{{form.password}}"
        bindinput="onInput" data-key="password"
        maxlength="20"
      />
    </view>

    <!-- 角色选择（仅注册） -->
    <view wx:if="{{mode === 'register'}}">
      <text class="role-title">选择身份</text>
      <view class="role-grid">
        <view
          class="role-card {{form.role === 'family' ? 'role-active-family' : ''}}"
          bindtap="selectRole" data-role="family"
        >
          <text class="role-emoji">👨‍👩‍👧</text>
          <text class="role-name">家属端</text>
          <text class="role-desc">查看轨迹、接收预警、管理记忆</text>
          <view class="role-check" wx:if="{{form.role === 'family'}}">✓</view>
        </view>
        <view
          class="role-card {{form.role === 'elderly' ? 'role-active-elderly' : ''}}"
          bindtap="selectRole" data-role="elderly"
        >
          <text class="role-emoji">👴</text>
          <text class="role-name">老人端</text>
          <text class="role-desc">SOS求助、AI伴聊、简洁模式</text>
          <view class="role-check" wx:if="{{form.role === 'elderly'}}">✓</view>
        </view>
      </view>
    </view>

    <!-- 错误提示 -->
    <view class="error-tip" wx:if="{{errorMsg}}">
      <text class="error-text">⚠️ {{errorMsg}}</text>
    </view>

    <!-- 提交按钮 -->
    <view
      class="submit-btn {{loading ? 'disabled' : ''}}"
      bindtap="submit"
    >
      <text wx:if="{{!loading}}">{{mode === 'login' ? '登 录' : '注 册'}}</text>
      <text wx:else>处理中…</text>
    </view>

    <!-- 切换提示 -->
    <view class="switch-tip">
      <text wx:if="{{mode === 'login'}}">还没有账号？</text>
      <text wx:else>已有账号？</text>
      <text
        class="switch-link"
        bindtap="setMode"
        data-m="{{mode === 'login' ? 'register' : 'login'}}"
      >{{mode === 'login' ? '立即注册' : '去登录'}}</text>
    </view>

  </view>

  <!-- 演示账号提示 -->
  <view class="demo-tip">
    <text class="demo-text">演示账号（家属）：138xxxxx01 / 123456</text>
    <text class="demo-text">演示账号（老人）：139xxxxx01 / 123456</text>
  </view>

</view>
