/* custom-tab-bar/index.wxss */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid rgba(15,23,42,0.08);
  display: flex;
  align-items: center;
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 8rpx;
  position: relative;
}

.tab-icon {
  position: relative;
  margin-bottom: 6rpx;
}

.icon-text {
  font-size: 44rpx;
  line-height: 1;
  filter: grayscale(100%) opacity(0.45);
}

.tab-item.active .icon-text {
  filter: none;
}

.tab-text {
  font-size: 20rpx;
  color: #94a3b8;
  letter-spacing: 1rpx;
}

.tab-item.active .tab-text {
  color: #f59e0b;
  font-weight: 600;
}

/* 未读角标 */
.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ff5c5c;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}
.badge-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
}
