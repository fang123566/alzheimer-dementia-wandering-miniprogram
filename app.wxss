/* app.wxss - 全局样式 */

/* ── 设计变量 ─────────────────────────────── */
page {
  --ink:        #f7f9fc;
  --ink-2:      #ffffff;
  --ink-3:      #eef3f8;
  --amber:      #f59e0b;
  --amber-light:#fbbf24;
  --amber-pale: rgba(245,158,11,0.14);
  --teal:       #14b8a6;
  --teal-pale:  rgba(20,184,166,0.12);
  --red:        #ef4444;
  --red-pale:   rgba(239,68,68,0.10);
  --green:      #22c55e;
  --green-pale: rgba(34,197,94,0.10);
  --glass:      rgba(255,255,255,0.92);
  --glass-border: rgba(15,23,42,0.08);
  --text:       #1f2937;
  --text-dim:   rgba(31,41,55,0.62);
  --text-faint: rgba(31,41,55,0.35);
  --radius:     20rpx;
  --radius-sm:  12rpx;

  /* 老人模式大字号变量 */
  --font-base:     28rpx;
  --font-lg:       32rpx;
  --font-xl:       36rpx;
  --font-xxl:      44rpx;

  background-color: #f7f9fc;
  color: #1f2937;
  font-family: -apple-system, 'PingFang SC', 'Noto Sans SC', sans-serif;
  font-size: var(--font-base);
}

/* 老人模式 - 大字号 */
page.elderly-mode {
  --font-base:     36rpx;
  --font-lg:       44rpx;
  --font-xl:       52rpx;
  --font-xxl:      64rpx;
}

/* ── 通用卡片 ─────────────────────────────── */
.card {
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

/* ── 状态标签 ─────────────────────────────── */
.tag {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  padding: 8rpx 22rpx;
  border-radius: 40rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
.tag-safe     { background: var(--green-pale);  color: var(--green); }
.tag-warning  { background: var(--amber-pale);  color: var(--amber); }
.tag-danger   { background: var(--red-pale);    color: var(--red);   }
.tag-teal     { background: var(--teal-pale);   color: var(--teal);  }

/* ── 按钮 ─────────────────────────────────── */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 0;
}
.btn-primary  { background: var(--amber);  color: #0d1b2a; }
.btn-danger   { background: var(--red);    color: #fff;    }
.btn-ghost    { background: var(--glass);  color: var(--text); border: 1rpx solid var(--glass-border); }

/* ── 页面头部 ────────────────────────────── */
.page-header {
  padding: 40rpx 32rpx 24rpx;
}
.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 2rpx;
}
.page-subtitle {
  font-size: 24rpx;
  color: var(--text-dim);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

/* ── 分割线 ──────────────────────────────── */
.divider {
  height: 1rpx;
  background: var(--glass-border);
  margin: 16rpx 0;
}

/* ── 列表行 ──────────────────────────────── */
.list-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--glass-border);
}
.list-row:last-child { border-bottom: none; }

/* ── 角色切换条 ──────────────────────────── */
.role-bar {
  display: flex;
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 6rpx;
  margin: 24rpx 32rpx;
}
.role-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: var(--text-dim);
  transition: all 0.2s;
}
.role-btn.active {
  background: var(--amber);
  color: #0d1b2a;
  font-weight: 700;
}
